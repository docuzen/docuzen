node_modules/
packages/*/dist/

# macOS Finder metadata
.DS_Store

# export bundles + unpack dirs generated for dev sample docs (review state
# itself lives in <repo-root>/.docuzen/, hidden globally — never ignore it here)
apps/desktop/sample/*.hadz
apps/desktop/sample/*.unpacked/

# parity harness output: reports + screenshots regenerated by each run
tools/parity/out/

# visual regression harness: current run + diff images regenerated by each
# run (tools/visual/baseline/ and tools/visual/fixtures/ ARE committed)
tools/visual/current/
tools/visual/diff/

# demo recording scratch (only docs/media/demo.gif is committed)
tools/demo/out/
tools/demo/*.webm
